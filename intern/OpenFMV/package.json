{
  "name": "openfmv",
  "version": "0.0.3",
  "description": "Visual non-linear storytelling editor",
  "private": true,
  "scripts": {
    "ipc:build": "node scripts/build-ipc-contract.js",
    "dev": "npm run ipc:build && node scripts/dev.js",
    "desktop": "npm run ipc:build && electron electron/main.js",
    "desktop:dev": "npm run ipc:build && electron electron/main.js",
    "build": "npm run ipc:build && node scripts/build.js",
    "prepare:standalone": "node scripts/prepare-standalone.js",
    "desktop:standalone": "npm run ipc:build && cmd /c \"set OPENFMV_USE_STANDALONE=1&& electron electron/main.js\"",
    "package:desktop": "npm run build && node scripts/package-desktop.js",
    "start": "next start",
    "lint": "eslint app electron i18n scripts shared __tests__ proxy.ts next.config.mjs postcss.config.js tailwind.config.js vitest.config.mts",
    "locale:guard": "node scripts/locale-guard.js",
    "test": "vitest",
    "test:ui": "vitest --ui",
    "test:run": "vitest run"
  },
  "keywords": [],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "@radix-ui/react-alert-dialog": "^1.1.15",
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-label": "^2.1.8",
    "@radix-ui/react-select": "^2.2.6",
    "@radix-ui/react-slot": "^1.2.4",
    "@types/dagre": "^0.7.53",
    "@xyflow/react": "^12.10.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "dagre": "^0.8.5",
    "html-to-image": "^1.11.13",
    "lucide-react": "^0.564.0",
    "next": "16.2.7",
    "next-intl": "^4.13.0",
    "react": "19.2.7",
    "react-dom": "19.2.7",
    "swr": "^2.4.0",
    "tailwind-merge": "^3.6.0",
    "tailwindcss-animate": "^1.0.7",
    "tldraw": "^5.0.1",
    "uuid": "^13.0.0",
    "zod": "^4.3.6",
    "zustand": "^5.0.11"
  },
  "devDependencies": {
    "@opentelemetry/api": "^1.1.0",
    "@types/node": "^20.0.0",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@types/uuid": "^11.0.0",
    "@vitest/ui": "^1.6.0",
    "autoprefixer": "^10.0.0",
    "dotenv": "^17.3.1",
    "electron": "^42.2.0",
    "eslint": "9.39.4",
    "eslint-config-next": "16.2.7",
    "happy-dom": "^14.12.3",
    "postcss": "^8.0.0",
    "rcedit": "^5.0.2",
    "sharp": "^0.34.5",
    "tailwindcss": "^3.4.0",
    "typescript": "^5.0.0",
    "vitest": "^1.6.0"
  }
}
